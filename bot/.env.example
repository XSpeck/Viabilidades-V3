# Token do bot — obtido com @BotFather no Telegram
BOT_TOKEN=123456789:AAABBBCCC...

# Firebase Admin SDK — escolha UMA das opções abaixo:

# Opção 1 (recomendada para produção/Fly.io): JSON completo da conta de serviço
# Cole o conteúdo do arquivo .json baixado do Firebase Console em uma única linha
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n","client_email":"...","client_id":"..."}

# Opção 2 (mais fácil para desenvolvimento local): três vars separadas
# FIREBASE_PROJECT_ID=seu-projeto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IDs dos grupos do Telegram (negativo = grupo/supergrupo)
# Para obter: rode "npm run get-ids" após adicionar o bot aos grupos
TELEGRAM_GROUP_AUDITORES=-100000000001
TELEGRAM_GROUP_AGENDAMENTO=-100000000002
TELEGRAM_GROUP_COMERCIAL_MF=-100000000003
TELEGRAM_GROUP_COMERCIAL=-100000000004
TELEGRAM_GROUP_ATENDIMENTO=-100000000005
TELEGRAM_GROUP_COMERCIAL_GMARX=-100000000006
