# Token do bot — obtido com @BotFather no Telegram
BOT_TOKEN=123456789:AAABBBCCC...

# Firebase Admin SDK — conta de serviço (JSON do console Firebase)
FIREBASE_PROJECT_ID=seu-projeto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@seu-projeto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# IDs dos grupos do Telegram (negativo = grupo/supergrupo)
# Para obter: adicione @userinfobot ao grupo e ele informa o ID
TELEGRAM_GROUP_AUDITORES=-100000000001
TELEGRAM_GROUP_AGENDAMENTO=-100000000002
TELEGRAM_GROUP_COMERCIAL_MF=-100000000003
TELEGRAM_GROUP_COMERCIAL=-100000000004
TELEGRAM_GROUP_ATENDIMENTO=-100000000005
TELEGRAM_GROUP_COMERCIAL_GMARX=-100000000006
