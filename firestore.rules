rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.nivel == 1;
    }

    // Usuários — cada um lê o próprio doc, admin lista e gerencia todos
    match /users/{uid} {
      allow get: if isAuth() && (request.auth.uid == uid || isAdmin());
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Viabilizações
    match /viabilizacoes/{id} {
      allow read, create, update: if isAuth();
      allow delete: if isAuth();
    }

    // Prédios atendidos
    match /predios_atendidos/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Prédios sem viabilidade
    match /predios_sem_viabilidade/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // CTOs (documento único agrupado)
    match /ctos_data/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Redes distribuidoras
    match /redes_distribuidoras/{id} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // Demandas de rede
    match /demandas_rede/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Fila de notificações do bot — escrita pelo app, leitura só via Admin SDK
    match /bot_notificacoes/{id} {
      allow create: if isAuth();
      allow read, update, delete: if false;
    }
  }
}
